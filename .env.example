# ─────────────────────────────────────────────────────────────────────────────
# Sense Platform — Environment Variables
# Copy this to .env and fill in your values.
# ─────────────────────────────────────────────────────────────────────────────

# ── Sense Relay (WebRTC server) ───────────────────────────────────────────────
SENSE_RELAY_URL=ws://localhost:7880
SENSE_RELAY_API_KEY=sense_gateway
SENSE_RELAY_SECRET=secret_change_in_production

# ── Room to join ─────────────────────────────────────────────────────────────
SENSE_ROOM=default

# ── LLM API Keys (choose one or more) ────────────────────────────────────────
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ── STT API Keys ──────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# ── TTS API Keys ──────────────────────────────────────────────────────────────
ELEVENLABS_API_KEY=
CARTESIA_API_KEY=

# ── Agent HTTP API ────────────────────────────────────────────────────────────
SENSE_MIND_PORT=8080
